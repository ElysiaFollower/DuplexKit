{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DuplexKit Mobile Demo",
  "version": "0.1.0",
  "identifier": "dev.duplexkit.mobile.demo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DuplexKit Mobile Demo",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "iOS": {
      "infoPlist": "Info.ios.plist"
    }
  }
}
