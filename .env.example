# Server
PORT=5177
PUBLIC_ORIGIN=http://localhost:5177

# Demo behavior
# Set to 1 to run without external ASR/LLM/TTS. Real API mode is the default.
DEMO_MOCK=0

# OpenAI-compatible LLM. DreamingRAG currently provides DEEPSEEK_API_KEY.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
# Optional compatibility aliases:
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# Volcengine ASR: 大模型录音文件极速版识别API
# Official endpoint: https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
VOLCENGINE_ASR_ENDPOINT=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
VOLCENGINE_ASR_APP_KEY=
VOLCENGINE_ASR_ACCESS_KEY=
VOLCENGINE_ASR_RESOURCE_ID=volc.bigasr.auc_turbo

# Volcengine TTS: HTTP SSE 单向流式-V3
# Official endpoint: https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse
VOLCENGINE_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse
VOLCENGINE_TTS_API_KEY=
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_SPEAKER=zh_female_shuangkuaisisi_moon_bigtts
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000

# DreamingRAG has this key; it can be used as TTS fallback only if it is a speech API key.
VOLCENGINE_API_KEY=
