# Server
PORT=5177
PUBLIC_ORIGIN=http://localhost:5177

# Demo behavior
# Set to 1 to run without external ASR/LLM/TTS. Real API mode is the default.
DEMO_MOCK=0
# Native realtime route. APP_ID/ACCESS_TOKEN aliases below are enough unless
# you want to override them only for realtime.
VOLCENGINE_REALTIME_ENDPOINT=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
VOLCENGINE_REALTIME_APP_ID=
VOLCENGINE_REALTIME_ACCESS_TOKEN=
VOLCENGINE_REALTIME_RESOURCE_ID=volc.speech.dialog
VOLCENGINE_REALTIME_APP_KEY=PlgvMymc7f3tQnJ6
VOLCENGINE_REALTIME_SPEAKER=zh_female_vv_jupiter_bigtts
VOLCENGINE_REALTIME_SAMPLE_RATE=24000

# Legacy HTTP debug route. Main browser demo does not need these.
# OpenAI-compatible LLM. DreamingRAG currently provides DEEPSEEK_API_KEY.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
# Optional compatibility aliases:
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# Legacy ASR debug route: 豆包流式语音识别模型2.0
# Official endpoint: wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
VOLCENGINE_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
VOLCENGINE_ASR_API_KEY=
VOLCENGINE_ASR_APP_KEY=
VOLCENGINE_ASR_ACCESS_KEY=
# Hourly: volc.seedasr.sauc.duration; concurrency: volc.seedasr.sauc.concurrent
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# Legacy TTS debug route: HTTP SSE 单向流式-V3
# Official endpoint: https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse
VOLCENGINE_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse
VOLCENGINE_TTS_API_KEY=
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_KEY=
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_SPEAKER=zh_female_xiaohe_uranus_bigtts
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000
# On macOS, keep a local `say` fallback enabled so the demo can still speak if
# the Volcengine speech key is missing or not authorized for TTS.
LOCAL_TTS_FALLBACK=1

# DreamingRAG has this key; it can be used as TTS fallback only if it is a speech API key.
VOLCENGINE_API_KEY=

# Old Volcengine speech console aliases. If present, these are used for realtime
# and legacy ASR/TTS old-console auth:
# - Realtime: X-Api-App-ID + X-Api-Access-Key
# - Legacy ASR: X-Api-App-Key + X-Api-Access-Key
# - TTS: X-Api-App-Id + X-Api-Access-Key
APP_ID=
ACCESS_TOKEN=
SECRET_KEY=
